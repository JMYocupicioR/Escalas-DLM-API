{
  "name": "medical-scales-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0 <21.0.0",
    "npm": ">=10.0.0 <11.0.0"
  },
  "scripts": {
    "dev": "cross-env EXPO_NO_TELEMETRY=1 expo start",
    "dev:pdf": "cross-env EXPO_PUBLIC_PDF_SERVICE_URL=http://localhost:8787 EXPO_NO_TELEMETRY=1 expo start",
    "dev:web:pdf": "cross-env EXPO_PUBLIC_PDF_SERVICE_URL=http://localhost:8787 EXPO_NO_TELEMETRY=1 expo start --web",
    "dev:pdf-service": "tsx server/pdf-service/src/index.ts",
    "build:web": "expo export --platform web",
    "build:functions": "tsc --project netlify/functions/tsconfig.json",
    "lint": "expo lint",
    "lint:app": "eslint app/(tabs)/index.tsx components/SearchWidget.tsx hooks/useAutoUpdatingScales.ts hooks/useThemedStyles.ts hooks/useResponsiveLayout.ts store/scales.ts data/_scales.ts app/theme.ts",
    "import:scales": "tsx scripts/massScaleImporter.ts",
    "import:template": "tsx scripts/massScaleImporter.ts template",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc -p tsconfig.app.json --noEmit"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.2.3",
    "@expo/vector-icons": "^14.0.2",
    "@gorhom/bottom-sheet": "^5.0.0-alpha.12",
    "@lucide/lab": "^0.1.2",
    "@netlify/functions": "^2.4.1",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-picker/picker": "2.9.0",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@supabase/supabase-js": "^2.56.0",
    "@tanstack/react-query": "^5.17.19",
    "expo": "~52.0.47",
    "expo-blur": "^14.0.3",
    "expo-clipboard": "~7.0.1",
    "expo-constants": "^17.0.5",
    "expo-file-system": "~18.0.12",
    "expo-font": "^13.0.3",
    "expo-haptics": "^14.0.1",
    "expo-linear-gradient": "^14.0.2",
    "expo-linking": "^7.0.5",
    "expo-print": "~14.0.3",
    "expo-router": "~4.0.21",
    "expo-secure-store": "^14.2.3",
    "expo-sharing": "~13.0.1",
    "expo-splash-screen": "~0.29.24",
    "expo-status-bar": "^2.0.1",
    "expo-symbols": "^0.2.2",
    "expo-system-ui": "~4.0.9",
    "expo-web-browser": "^14.0.2",
    "jspdf": "^3.0.2",
    "logrocket": "^10.1.0",
    "lucide-react-native": "^0.475.0",
    "puppeteer": "^24.17.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-paper": "^5.12.3",
    "react-native-reanimated": "^3.16.7",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.19.13",
    "react-native-webview": "13.12.5",
    "zod": "^3.23.8",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.5",
    "@types/node": "^20.19.11",
    "@types/react": "~18.3.12",
    "cross-env": "^10.0.0",
    "csv-parser": "^3.0.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~8.0.1",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.6",
    "react-test-renderer": "18.3.1",
    "tsx": "^4.0.0",
    "typescript": "^5.3.3"
  }
}
