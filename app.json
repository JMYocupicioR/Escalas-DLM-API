{
  "expo": {
    "name": "Escalas DLM",
    "slug": "escalas-dlm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "escalas-dlm",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "description": "Escalas médicas clínicas validadas científicamente — DeepLux Med",
    "keywords": ["medicina", "escalas", "evaluacion", "clinica", "salud", "DLM"],
    "privacy": "unlisted",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.deepluxmed.escalas",
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0ea5e9"
      },
      "package": "com.deepluxmed.escalas"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png",
      "name": "Escalas DLM — DeepLux Med",
      "shortName": "Escalas DLM",
      "description": "Escalas médicas y calculadoras profesionales — DeepLux Med",
      "themeColor": "#0ea5e9",
      "backgroundColor": "#0f172a"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
