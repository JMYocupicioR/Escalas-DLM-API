{
  "expo": {
    "name": "DeepLuxMed - Escalas Médicas",
    "slug": "deepluxmed-escalas",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "deepluxmed",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "description": "Aplicación médica profesional para evaluación de escalas clínicas y calculadoras especializadas.",
    "keywords": ["medicina", "escalas", "evaluacion", "clinica", "salud"],
    "privacy": "unlisted",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.deepluxmed.escalas",
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0891b2"
      },
      "package": "com.deepluxmed.escalas"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png",
      "name": "DeepLuxMed - Escalas Médicas",
      "shortName": "DeepLuxMed",
      "description": "Escalas médicas y calculadoras profesionales",
      "themeColor": "#0891b2",
      "backgroundColor": "#f8fafc"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
